{
  "manifest_version": 3,
  "name": "Peakr",
  "version": "1.0",
  "description": "Rankea mediante duelos 1v1.",
  "permissions": ["sidePanel", "storage", "tabs", "downloads"],
  "host_permissions": [
    "https://api.deezer.com/",
    "https://www.deezer.com/",
    "https://cdnt-preview.dzcdn.net/"
  ],
  "action": {
    "default_title": "Abrir Peakr"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "side_panel": {
    "default_path": "ui/ui.html"
  }
}
